<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Digital Profile - Vũ Minh Đại | JOYWORK</title>
    <link rel="stylesheet" href="styles.css">
</head>
<body>
    <div class="background"></div>
    <canvas id="fireworksCanvas"></canvas>
    
    <div class="container">
        <div class="profile-card">
            <!-- Profile Image -->
            <div class="profile-image-container">
                <img src="https://scontent.fhan15-1.fna.fbcdn.net/v/t39.30808-6/419516713_881715510103231_5987274002261128769_n.jpg?_nc_cat=105&ccb=1-7&_nc_sid=53a332&_nc_eui2=AeHL99HEA11lNzEPsGujDd9FpEUHRCrC5fukRQdEKsLl-2eTmZQbXQYYjYLAKiNurjD8bzIzBMjuHqSR5-qNMydw&_nc_ohc=xJ3DCmbP3NcQ7kNvwF3jNMU&_nc_oc=AdrdKBKiwQuiPnjGdjpEFF9QiPg5w9_UIC-4xd1p7W0-7J3oMPGS2prVnh24gLbBwEM&_nc_zt=23&_nc_ht=scontent.fhan15-1.fna&_nc_gid=OYvrJMsUlaFvilfMoNm7HA&_nc_ss=7a3a8&oh=00_Af3DyvxENa8pVqdXjFDDtPibTxZ757HTDxhvtP3NNiUokA&oe=69DD563B" alt="Profile" class="profile-image">
                <div class="image-border"></div>
            </div>

            <!-- Profile Info -->
            <div class="profile-info">
                <h1 class="name">Vũ Minh Đại</h1>
                <p class="position">Nhân viên @ JOYWORK</p>
                <p class="company">JOYWORK Company</p>
            </div>

            <!-- Social Links & Buttons -->
            <div class="button-group">
                <a href="https://www.facebook.com/vu.huge.7" target="_blank" class="btn btn-facebook">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                    </svg>
                    Facebook
                </a>
                <button class="btn btn-gift" onclick="triggerFireworks()">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="1"></circle>
                        <path d="M12 1v6m6 6h6m-6-6l-4.24 4.24M12 1H6v6m0 0L1.76 11.24M12 23v-6m-6-6H0m6 0l4.24-4.24M12 23h6v-6m0 0l4.24-4.24"></path>
                        <rect x="5" y="5" width="14" height="14" rx="2"></rect>
                    </svg>
                    Tặng Quà
                </button>
            </div>

            <!-- Decorative Elements -->
            <div class="stars">
                <div class="star"></div>
                <div class="star"></div>
                <div class="star"></div>
                <div class="star"></div>
                <div class="star"></div>
            </div>
        </div>

        <!-- Message Section -->
        <div class="message-section">
            <div class="message-container">
                <h2 class="message-title">💌 Để lại lời nhắn</h2>
                
                <!-- Message Form -->
                <div class="message-form">
                    <input type="text" id="senderName" class="input-field" placeholder="Tên của bạn" maxlength="50">
                    <textarea id="messageText" class="textarea-field" placeholder="Lời nhắn của bạn..." maxlength="300" rows="4"></textarea>
                    <button class="btn btn-send" onclick="sendMessage()">Gửi Lời Nhắn ✉️</button>
                </div>

                <!-- Messages List -->
                <div class="messages-list" id="messagesList">
                    <!-- Messages will be displayed here -->
                </div>
            </div>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
